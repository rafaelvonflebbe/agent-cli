{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD (Product Requirements Document)",
  "description": "Schema for the prd.json file used by Agent CLI",
  "type": "object",
  "required": ["project", "branchName", "description", "userStories"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name",
      "minLength": 1
    },
    "branchName": {
      "type": "string",
      "description": "Git branch name for this feature"
    },
    "description": {
      "type": "string",
      "description": "Feature description",
      "minLength": 1
    },
    "userStories": {
      "type": "array",
      "description": "User stories to implement",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "acceptanceCriteria", "priority", "passes", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier (e.g., 'US-001')",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "description": "Human-readable title",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the story",
            "minLength": 1
          },
          "acceptanceCriteria": {
            "type": "array",
            "description": "Acceptance criteria for completion",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "type": "number",
            "description": "Priority (lower = higher priority)",
            "minimum": 1
          },
          "passes": {
            "type": "boolean",
            "description": "Whether the story has been completed"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes or context"
          },
          "dependsOn": {
            "type": "array",
            "description": "Story IDs this story depends on (all must have passes: true before this story is eligible)",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "projectDirectory": {
      "type": "string",
      "description": "Path to the project directory where the AI tool works (cwd for the spawned process). If omitted, defaults to the directory containing prd.json."
    },
    "mcpServers": {
      "type": "array",
      "description": "MCP servers to attach to ACP sessions for this project.",
      "items": {
        "type": "object",
        "required": ["name", "command", "args"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable name for this MCP server",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "description": "Command to launch the MCP server",
            "minLength": 1
          },
          "args": {
            "type": "array",
            "description": "Arguments for the MCP server command",
            "items": {
              "type": "string"
            }
          },
          "env": {
            "type": "object",
            "description": "Environment variables to set when launching the MCP server",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "stopWhen": {
      "type": "object",
      "description": "Custom conditions for when the agent loop should stop (OR logic — any condition triggers a stop).",
      "additionalProperties": false,
      "properties": {
        "stories": {
          "type": "array",
          "description": "Stop when these specific story IDs are completed",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "maxCostUsd": {
          "type": "number",
          "description": "Stop when accumulated cost exceeds this threshold in USD (ACP only)",
          "exclusiveMinimum": 0
        },
        "maxDurationMinutes": {
          "type": "number",
          "description": "Stop when total session time exceeds this limit in minutes",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
