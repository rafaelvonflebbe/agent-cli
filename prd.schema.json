{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD (Product Requirements Document)",
  "description": "Schema for the prd.json file used by Agent CLI",
  "type": "object",
  "required": ["project", "branchName", "description", "userStories"],
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name",
      "minLength": 1
    },
    "branchName": {
      "type": "string",
      "description": "Git branch name for this feature"
    },
    "description": {
      "type": "string",
      "description": "Feature description",
      "minLength": 1
    },
    "userStories": {
      "type": "array",
      "description": "User stories to implement",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "acceptanceCriteria", "priority", "passes", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier (e.g., 'US-001')",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "description": "Human-readable title",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the story",
            "minLength": 1
          },
          "acceptanceCriteria": {
            "type": "array",
            "description": "Acceptance criteria for completion",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "type": "number",
            "description": "Priority (lower = higher priority)",
            "minimum": 1
          },
          "passes": {
            "type": "boolean",
            "description": "Whether the story has been completed"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes or context"
          }
        }
      }
    }
  }
}
